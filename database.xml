<?xml version="1.0" encoding="UTF-8"?>
<database>

    <global>
        <table name="payments">
            <field type="integer" autoincrement="true" primary="true">id</field>
            <field type="boolean" default="0">active</field>
            <field type="string" length="255">payment_type</field>
            <field type="string" length="255">icon</field>
            <field type="text" nullable="true" default="null">date_from</field>
            <field type="text" nullable="true" default="null">date_until</field>
            <field type="integer" nullable="true" default="0">purchase_quantity_from</field>
            <field type="integer" nullable="true" default="0">purchase_quantity_until</field>
            <field type="text" nullable="true" default="null">purchase_value_from</field>
            <field type="text" nullable="true" default="null">purchase_value_until</field>

            <field type="integer" nullable="true" default="null">priority</field>
            <field type="float" nullable="true" default="null">paymentFee</field>

            <field type="text" nullable="true" default="null">areas</field>
            <field type="text" nullable="true" default="null">articles</field>
            <field type="text" nullable="true" default="null">categories</field>
            <field type="text" nullable="true" default="null">user_groups</field>
            <field type="text" nullable="true" default="null">currencies</field>

            <index>active</index>
            <index>payment_type</index>
            <index>priority</index>
        </table>
    </global>

</database>
